<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0F1E"> <RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:background="#0D47A1"
    android:padding="20dp">

    <RelativeLayout
        android:id="@+id/rlPhotoEdit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/ivProfilePhoto"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/circle_avatar"
            android:scaleType="centerCrop"
            android:contentDescription="Profile Photo" />

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignBottom="@id/ivProfilePhoto"
            android:layout_alignEnd="@id/ivProfilePhoto"
            android:src="@android:drawable/ic_menu_edit"
            android:tint="#131929"
            android:padding="5dp"
            app:backgroundTint="#FFFFFF"
            android:background="@drawable/circle_avatar_edit" /> </RelativeLayout>

    <TextView
        android:id="@+id/tvProfileName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/rlPhotoEdit"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:text="Teacher Name"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />
</RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardBackgroundColor="#131929"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assigned Subject"
                android:textColor="#60A5FA"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvProfileSubject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mathematics"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textColor="#60A5FA"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="rehan@example.com"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="25dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E2D4A"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnChangePassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Reset Password via Email"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#1E2D4A"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>