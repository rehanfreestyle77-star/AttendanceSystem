<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0F1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0D47A1"
        android:padding="30dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Teacher"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Register a new teacher to the portal"
            android:textColor="#90CAF9"
            android:textSize="14sp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Teacher Details"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#60A5FA"
                android:layout_marginBottom="15dp"/>

            <EditText
                android:id="@+id/etTeacherName"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Full Name"
                android:inputType="textPersonName"
                android:textColor="#FFFFFF"
                android:textColorHint="#64748B"
                android:background="#131929"
                android:paddingStart="15dp"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/etTeacherEmail"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Email Address"
                android:inputType="textEmailAddress"
                android:textColor="#FFFFFF"
                android:textColorHint="#64748B"
                android:background="#131929"
                android:paddingStart="15dp"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/etTeacherPhone"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Phone Number"
                android:inputType="phone"
                android:textColor="#FFFFFF"
                android:textColorHint="#64748B"
                android:background="#131929"
                android:paddingStart="15dp"
                android:layout_marginBottom="10dp"/>

            <Spinner
                android:id="@+id/spinnerTeacherSubject"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="#131929"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/etTeacherPassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Temporary Password (Min 6 chars)"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#64748B"
                android:background="#131929"
                android:paddingStart="15dp"
                android:layout_marginBottom="20dp"/>

            <Button
                android:id="@+id/btnSaveTeacher"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Create Teacher Account"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0D47A1"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>